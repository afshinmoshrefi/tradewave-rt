# TradeWave Realtime - secrets template.
#
# In this deployment, secrets live OUTSIDE the app dir, at:
#     /etc/tradewave_realtime/secrets.env   (root:root, 0600)
# loaded by systemd (EnvironmentFile=) and by config.py for manual runs.
# Copy this file there and fill it in:
#     install -m 0600 .env.example /etc/tradewave_realtime/secrets.env && edit it
#
# SECRET_KEY is required (config auto-generates a throwaway one if unset).
SECRET_KEY=change-me-to-a-long-random-string

# Optional: when set, the "Anne-Marie" coach uses Claude. When unset, the coach
# runs in retrieval-only demo mode (still fully clickable for the demo).
# Named ANTHROPIC_TOKEN for consistency across the apps.
ANTHROPIC_TOKEN=
# Haiku 4.5 - cheap + fast, matches the EOD chatbot. Pin as claude-haiku-4-5-20251001 if preferred.
CLAUDE_MODEL=claude-haiku-4-5

# Comma-separated emails that become admins on signup (Anne-Marie + Afshin).
ADMIN_EMAILS=anne-marie@thetradingbook.com,afshin@tradewave.ai

# Dev server port (gunicorn binds this)
PORT=5001
