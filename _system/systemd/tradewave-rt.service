[Unit]
Description=TradeWave Realtime (gunicorn / Flask)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/flask/tradewave_realtime
Environment=PATH=/home/flask/tradewave_realtime/.venv/bin
EnvironmentFile=/etc/tradewave_realtime/secrets.env
ExecStart=/home/flask/tradewave_realtime/.venv/bin/gunicorn -w 2 --threads 8 -b 0.0.0.0:5001 --access-logfile - wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
